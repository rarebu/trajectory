DATABASE_URL=postgres://trajectory:trajectory@localhost:5432/trajectory
DATA_DIR=./data
RUST_LOG=info

# AIS -- https://aisstream.io
AIS_API_KEY=

# OpenSky Network (optional, raises rate limits)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Private ADS-B feeder. Leave unset to disable.
BRATWURST_LOGIN_URL=
BRATWURST_API_URL=
BRATWURST_USERNAME=
BRATWURST_PASSWORD=

# Source toggles
AIS_ENABLED=1
SATELLITES_ENABLED=1
TRAINS_ENABLED=1
GTFS_RT_ENABLED=1
GTFS_STATIC_ENABLED=1
ADSB_OPENSKY_ENABLED=1
ADSB_LOL_ENABLED=1
ADSB_FI_ENABLED=1
ADSB_ONE_ENABLED=1
ADSB_AIRPLANESLIVE_ENABLED=1
ADSB_BRATWURST_ENABLED=0

# Intervals (uncomment to override defaults)
# FLIGHTS_INTERVAL_SECS=300
# TRAINS_INTERVAL_SECS=900
# GTFS_RT_INTERVAL_SECS=120
# GTFS_STATIC_INTERVAL_SECS=86400
# SATELLITES_INTERVAL_SECS=21600
# BRATWURST_INTERVAL_SECS=60
# ADSB_ONE_DELAY_MS=1500
# AIS_DEDUP_ENABLED=1

# Retention (days; unset = no retention policy)
# RETENTION_SHIPS_DAYS=30
# RETENTION_FLIGHTS_DAYS=30
# RETENTION_DEPARTURES_DAYS=90
# RETENTION_VEHICLE_POSITIONS_DAYS=30
# RETENTION_SERVICE_ALERTS_DAYS=90
